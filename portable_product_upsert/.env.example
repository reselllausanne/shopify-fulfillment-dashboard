# Copy this file to .env and paste values from the main Shopify automation codebase.
# Required for Shopify Admin GraphQL:
SHOP_NAME_SHOPIFY=
ACCESS_TOKEN_SHOPIFY=
API_VERSION_SHOPIFY=2026-04

# Optional aliases (used as fallbacks by shopifyAPI_GQL.py):
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=

# Primary online inventory location (default in code = Chemin de Bas-de-Plan)
SHOPIFY_ONLINE_LOCATION_ID=gid://shopify/Location/72553660705
SHOPIFY_ONLINE_LOCATION_NAME=Chemin de Bas-de-Plan

# Optional Kicks/StockX key (code has fallback if empty)
KICKSDB_API_KEY=

# Optional tuning
SHOPIFY_VERBOSE_HTTP=0
STOCKX_REQUEST_DELAY_SEC=0
STOCKX_MAX_RETRIES=5
STOCKX_TIMEOUT_SEC=25
