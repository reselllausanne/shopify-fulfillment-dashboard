  createdAt  DateTime @default(now())

  order      GalaxusOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@schema("public")
}

model Document {
  id         String   @id @default(uuid())
  orderId    String?
  shipmentId String?
  type       DocumentType
  version    Int      @default(1)
  storageUrl String
  checksum   String?
  createdAt  DateTime @default(now())

  order      GalaxusOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  shipment   Shipment?     @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([shipmentId])
  @@schema("public")
}

enum GalaxusEdiDirection {
  IN
  OUT

  @@schema("public")
}

enum GalaxusEdiDocType {
  ORDP
  ORDR
  DELR
  EXPINV
  INVO
  EOLN
  CANP
  CANR

  @@schema("public")
}

model GalaxusEdiFile {
  id           String              @id @default(uuid())
  direction    GalaxusEdiDirection
  docType      GalaxusEdiDocType
  orderId      String?
  orderRef     String?
  shipmentId   String?
  filename     String              @unique
  checksum     String?
  status       String
  errorMessage String?
  payloadJson  Json?
  processedAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  order        GalaxusOrder?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  shipment     Shipment?           @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  @@index([direction, docType])
  @@index([orderRef])
  @@index([shipmentId])
  @@unique([shipmentId, direction, docType])
  @@schema("public")
}

model GalaxusJobDefinition {
  id         String   @id @default(uuid())
  jobKey     String   @unique
  intervalMs Int
  enabled    Boolean  @default(true)
  lastRunAt  DateTime?
  nextRunAt  DateTime?
  lastError  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@schema("public")
}

model GalaxusFeedRun {
  id              String   @id @default(uuid())
  runId           String
  scope           String
  triggerSource   String?
  startedAt       DateTime
  finishedAt      DateTime?
  success         Boolean  @default(false)
  errorMessage    String?
  countsJson      Json?
  manifestIds     String[]
  createdAt       DateTime @default(now())

  @@index([runId])
  @@index([scope, startedAt])
  @@schema("public")
}

model GalaxusFeedTrigger {
  id            String   @id @default(uuid())
  scope         String
  triggerSource String?
  requestedAt   DateTime @default(now())
  consumedAt    DateTime?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())

  @@index([scope, requestedAt])
  @@index([status])
  @@schema("public")
}

model GalaxusJobRun {
  id           String   @id @default(uuid())
  jobName      String
  runId        String?
  supplierKey  String?
  startedAt    DateTime
  finishedAt   DateTime
  success      Boolean
  errorMessage String?
  resultJson   Json?
  createdAt    DateTime @default(now())

  @@index([jobName, startedAt])
  @@index([runId])
  @@schema("public")
}

model GalaxusJobQueue {
  id           String   @id @default(uuid())
  jobType      String
  status       String   @default("PENDING")
  groupKey     String?
  payloadJson  Json?
  resultJson   Json?
  priority     Int      @default(0)
  attempts     Int      @default(0)
  maxAttempts  Int      @default(5)
  lockedAt     DateTime?
  lockedBy     String?
  startedAt    DateTime?
  finishedAt   DateTime?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([jobType, status, priority, createdAt])
  @@index([status])
  @@index([groupKey])
  @@schema("public")
}

model GalaxusExportManifest {
  id                    String   @id @default(uuid())
  runId                 String
  exportType            String
  supplierKeys          String[]
  productCount          Int
  checksum              String?
  storagePointer        String?
  destination           String?
  uploadStatus          String
  responseJson          Json?
  validationIssuesJson  Json?
  createdAt             DateTime @default(now())

  @@index([runId])
  @@index([exportType])
  @@schema("public")
}

model DecathlonExportRun {
  id             String   @id @default(uuid())
  runId          String   @unique
  startedAt      DateTime
  finishedAt     DateTime?
  success        Boolean  @default(false)
  errorMessage   String?
  countsJson     Json?
  exclusionsJson Json?
  createdAt      DateTime @default(now())

  files          DecathlonExportFile[]

  @@index([startedAt])
  @@schema("public")
}

model DecathlonExportFile {
  id         String   @id @default(uuid())
  runId      String
  fileType   String
  rowCount   Int      @default(0)
  checksum   String?
  storageUrl String?
  publicUrl  String?
  sizeBytes  Int?
  createdAt  DateTime @default(now())

  exportRun  DecathlonExportRun @relation(fields: [runId], references: [runId], onDelete: Cascade)

  @@index([runId])
  @@index([fileType])
  @@index([runId, fileType])
  @@schema("public")
}

enum DecathlonImportFlow {
  OF01
  STO01
  PRI01
  P41

  @@schema("public")
}

enum DecathlonImportMode {
  NORMAL
  REPLACE
  TEST

  @@schema("public")
}

enum DecathlonImportStatus {
  CREATED
  RUNNING
  SUCCESS
  PARTIAL
  FAILED

  @@schema("public")
}

model DecathlonOfferSync {
  id                String   @id @default(uuid())
  providerKey       String   @unique
  supplierVariantId String?
  gtin              String?
  productStatus     String?
  productStatusCheckedAt DateTime?
  lastProductSyncAt DateTime?
  lastStock         Int?
  lastPrice         Decimal? @db.Decimal(10, 2)
  lastStockSyncedAt DateTime?
  lastPriceSyncedAt DateTime?
  offerCreatedAt    DateTime?
  lastOfferSyncAt   DateTime?
  lastError         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([supplierVariantId])
  @@schema("public")
}

model DecathlonImportRun {
  id               String                @id @default(uuid())
  runId            String                @unique
  flow             DecathlonImportFlow
  mode             DecathlonImportMode
  status           DecathlonImportStatus @default(CREATED)
  importId         String?
  rowsSent         Int                   @default(0)
  linesInError     Int?
  startedAt        DateTime              @default(now())
  finishedAt       DateTime?
  summaryJson      Json?
  errorSummaryJson Json?
  errorStorageUrl  String?
  errorPublicUrl   String?
  errorChecksum    String?
  errorSizeBytes   Int?
  errorSampleJson  Json?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([flow, startedAt])
  @@index([importId])
  @@schema("public")
}
