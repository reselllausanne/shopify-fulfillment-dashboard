// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model StockXToken {
  id        Int      @id @default(autoincrement())
  token     String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@schema("public")
}

// Source of truth for ALL Shopify orders (booked sales)
// Populated independently from matching
model ShopifyOrder {
  shopifyOrderId      String    @id
  orderName           String
  createdAt           DateTime  // Shopify sell date
  totalSalesChf       Decimal   @db.Decimal(10, 2)  // Gross sales
  currencyCode        String    @default("CHF")
  financialStatus     String?
  paymentGatewayNames String[] @default([])
  cancelledAt         DateTime?
  refundedAmountChf   Decimal?  @db.Decimal(10, 2)
  netSalesChf         Decimal?  @db.Decimal(10, 2)  // totalSales - refunded
  updatedAt           DateTime  @updatedAt
  syncedAt            DateTime  @default(now())

  @@index([createdAt])
  @@schema("public")
}

enum SupplierSource {
  STOCKX
  MANUAL
  OTHER

  @@schema("public")
}

enum ReturnReason {
  STORE_CREDIT
  EXCHANGE
  DAMAGE

  @@schema("public")
}

enum StxImportSlugStatus {
  PENDING
  IMPORTED
  ERROR

  @@schema("public")
}

model OrderMatch {
  id                      String   @id @default(uuid())
  
  // Shopify identifiers
  shopifyOrderId          String
  shopifyOrderName        String
  shopifyLineItemId       String   @unique
  shopifyProductTitle     String
  shopifySku              String?
  shopifySizeEU           String?
  shopifyTotalPrice       Decimal  @db.Decimal(10, 2)
  shopifyCurrencyCode     String   @default("CHF")
  shopifyCreatedAt        DateTime?
  shopifyCustomerEmail    String?
  shopifyCustomerFirstName String?
  shopifyCustomerLastName  String?
  shopifyLineItemImageUrl String?
  
  // Supplier identifiers (supports StockX, manual, other)
  supplierSource          SupplierSource @default(STOCKX)
  stockxOrderNumber       String         // Can be used for manual ref too
  stockxChainId           String?        // StockX long chainId (e.g. "14826275139352606543")
  stockxOrderId           String?        // StockX orderId (often = orderNumber)
  stockxProductName       String
  stockxSizeEU            String?
  stockxSkuKey            String?
  stockxPurchaseDate      DateTime?      // Also: supplierPurchaseDate
  
  // Match metadata
  matchConfidence         String
  matchScore              Decimal  @db.Decimal(5, 2)
  matchType               String
  matchReasons            String
  timeDiffHours           Decimal? @db.Decimal(10, 2)
  
  // StockX status & tracking
  stockxStatus              String
  stockxTrackingUrl         String?        // Tracking URL from shipping.shipment
  stockxAwb                 String?        // Air Waybill / tracking number (extracted from trackingUrl)
  stockxEstimatedDelivery   DateTime?      // Estimated delivery date (start)
  stockxLatestEstimatedDelivery DateTime?  // Latest estimated delivery date (end)
  stockxCheckoutType        String?
  stockxStates              Json?
  stockxStatesHash          String?
  stockxStatesUpdatedAt     DateTime?

  lastMilestoneKey          String?
  lastMilestoneAt           DateTime?

  /// Opaque token for public customer tracking (/track/[token]); no expiry.
  customerTrackingToken   String?  @unique

  stockxStatusEvents        StockXStatusEvent[]
  
  // Shopify metafields sync status
  shopifyMetafieldsSynced Boolean  @default(false)
  shopifyMetafieldsSetAt  DateTime?
  
  // Financial data
  supplierCost            Decimal  @db.Decimal(10, 2)
  marginAmount            Decimal  @db.Decimal(10, 2)
  marginPercent           Decimal  @db.Decimal(5, 2)

  // Returns handling
  returnReason            ReturnReason?
  returnFeePercent        Decimal? @db.Decimal(5, 2)
  returnFeeAmountChf      Decimal? @db.Decimal(10, 2)
  returnAppliedAt         DateTime?
  returnedStockValueChf   Decimal? @db.Decimal(10, 2)
  
  // Manual overrides
  manualCostOverride      Decimal? @db.Decimal(10, 2)
  manualCaseStatus        String?
  manualRevenueAdjustment Decimal? @db.Decimal(10, 2)
  manualNote              String?
  
  // Timestamps
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  @@index([shopifyOrderId])
  @@index([stockxOrderNumber])
  @@index([shopifyMetafieldsSynced])
  @@index([stockxPurchaseDate])
  @@schema("public")
}

model GalaxusStockxMatch {
  id                 String   @id @default(uuid())

  galaxusOrderId     String
  galaxusOrderRef    String?
  galaxusOrderDate   DateTime?
  galaxusOrderLineId String
  unitIndex          Int      @default(0)
  galaxusLineNumber  Int?
  galaxusProductName String
  galaxusDescription String?
  galaxusSize        String?
  galaxusGtin        String?
  galaxusProviderKey String?
  galaxusSupplierSku String?
  galaxusQuantity    Int
  galaxusUnitNetPrice Decimal @db.Decimal(10, 2)
  galaxusLineNetAmount Decimal @db.Decimal(10, 2)
  galaxusVatRate     Decimal @db.Decimal(5, 2)
  galaxusCurrencyCode String   @default("CHF")

  stockxChainId      String?
  stockxOrderId      String?
  stockxOrderNumber  String
  stockxVariantId    String?
  stockxProductName  String?
  stockxSkuKey       String?
  stockxSizeEU       String?
  stockxPurchaseDate DateTime?
  stockxAmount       Decimal? @db.Decimal(10, 2)
  stockxCurrencyCode String?
  stockxStatus       String?
  stockxEstimatedDelivery DateTime?
  stockxLatestEstimatedDelivery DateTime?
  stockxAwb          String?
  stockxTrackingUrl  String?
  stockxCheckoutType String?
  stockxStates       Json?

  matchConfidence    String?
  matchScore         Decimal? @db.Decimal(5, 2)
  matchType          String?
  matchReasons       String?
  timeDiffHours      Decimal? @db.Decimal(10, 2)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  order              GalaxusOrder     @relation(fields: [galaxusOrderId], references: [id], onDelete: Cascade)
  orderLine          GalaxusOrderLine @relation(fields: [galaxusOrderLineId], references: [id], onDelete: Cascade)

  @@unique([galaxusOrderLineId, unitIndex])
  @@index([galaxusOrderId])
  @@index([stockxOrderNumber])
  @@index([stockxVariantId])
  @@schema("public")
}

model StockXStatusEvent {
  id             String   @id @default(uuid())
  orderMatchId   String
  milestoneKey   String
  milestoneTitle String
  statesHash     String
  createdAt      DateTime @default(now())

  // Email delivery state (for reliable + deduped notifications)
  emailTo         String?
  emailProvider   String?  // e.g. "postmark"
  emailProviderId String?  // provider message id
  emailedAt       DateTime?
  emailError      String?

  orderMatch     OrderMatch @relation(fields: [orderMatchId], references: [id], onDelete: Cascade)

  @@unique([orderMatchId, milestoneKey])
  @@index([orderMatchId])
  @@schema("public")
}


model ShopifyFulfillmentRecord {
  id              String   @id @default(uuid())
  shopifyOrderId  String
  shopifyOrderName String?
  trackingNumber  String
  trackingUrl     String?
  trackingCompany String?
  status          String?
  sourceAwb       String?
  swissPostLabelId  String?
  swissPostLabelUrl String?
  swissPostBarcode  String?
  swissPostStatus   String?
  swissPostResponse Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shopifyOrderId])
  @@index([trackingNumber])
  @@unique([shopifyOrderId, trackingNumber])
  @@schema("public")
}

model OrderMetric {
  shopifyOrderId String   @id
  createdAt      DateTime
  grossSales     Decimal  @db.Decimal(10, 2)
  marginChf      Decimal  @db.Decimal(10, 2)
  marginPct      Decimal  @db.Decimal(5, 2)
  currency       String   @default("CHF")
  updatedAt      DateTime @updatedAt

  @@index([createdAt])
  @@schema("public")
}

// ERP Models for AppSheet
enum ExpenseType {
  PERSONAL
  BUSINESS

  @@schema("public")
}

model ExpenseCategory {
  id        String        @id @default(uuid())
  name      String        @unique
  type      ExpenseType   @default(PERSONAL)
  createdAt DateTime      @default(now())
  
  expenses            PersonalExpense[]
  recurringExpenses   RecurringExpense[]
  manualFinanceEvents ManualFinanceEvent[]

  @@schema("public")
}

model PaymentAccount {
  id        String   @id @default(uuid())
  name      String   @unique
  provider  String
  last4     String?
  currency  String   @default("CHF")
  createdAt DateTime @default(now())
  
  expenses  PersonalExpense[]
  recurringExpenses RecurringExpense[]

  @@schema("public")
}

model PersonalExpense {
  id           String         @id @default(uuid())
  date         DateTime
  amount       Decimal        @db.Decimal(10, 2)
  currencyCode String         @default("CHF")
  categoryId   String
  accountId    String
  note         String?
  isBusiness   Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  
  category     ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  account      PaymentAccount  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  
  @@index([date])
  @@index([categoryId])
  @@index([accountId])
  @@index([isBusiness])
  @@schema("public")
}

model DailyAdSpend {
  date      DateTime @id
  amountChf Decimal  @db.Decimal(10, 2)
  channel   String   @default("google")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@schema("public")
}

model MonthlyVariableCosts {
  monthKey              String   @id
  year                  Int
  month                 Int
  postageShippingCostChf Decimal @db.Decimal(10, 2)
  fulfillmentCostChf    Decimal  @db.Decimal(10, 2)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@unique([year, month])
  @@schema("public")
}

model RecurringExpense {
  id           String   @id @default(uuid())
  name         String
  amount       Decimal  @db.Decimal(10, 2)
  currencyCode String   @default("CHF")
  categoryId   String
  accountId    String
  isBusiness   Boolean  @default(false)
  dayOfMonth   Int      @default(1)
  intervalMonths Int    @default(1) // 1=monthly, 3=quarterly, etc.
  startDate    DateTime @default(now())
  endDate      DateTime?
  nextRunDate  DateTime
  lastRunAt    DateTime?
  active       Boolean  @default(true)
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category     ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  account      PaymentAccount  @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([nextRunDate])
  @@index([active])
  @@schema("public")
}

enum MarketplaceChannel {
  SHOPIFY
  GALAXUS
  DECATHLON

  @@schema("public")
}

enum CashInDelayType {
  BUSINESS_DAYS
  CALENDAR_DAYS
  NEXT_FRIDAY

  @@schema("public")
}

enum CashOutCadence {
  DAILY
  WEEKLY
  MONTHLY

  @@schema("public")
}

enum CashOutCategory {
  COGS
  ADS
  SHIPPING
  SUBSCRIPTION
  OWNER_DRAW
  INSURANCE
  FUEL
  OTHER

  @@schema("public")
}

enum ForecastMode {
  AUTO
  MANUAL
  HYBRID

  @@schema("public")
}

enum BankAccountType {
  BANK
  CARD

  @@schema("public")
}

enum BankImportSource {
  CAMT053
  CSV

  @@schema("public")
}

enum FinanceDirection {
  IN
  OUT

  @@schema("public")
}

enum FinanceCategory {
  SALES
  REFUND
  COGS
  COMMISSION
  SHIPPING
  ADS
  SUBSCRIPTION
  OWNER_DRAW
  INSURANCE
  FUEL
  TAX
  OTHER

  @@schema("public")
}

enum ManualEventSourceType {
  MANUAL
  RECURRING
  IMPORT

  @@schema("public")
}

enum OperatingEventType {
  SALE
  REFUND
  COGS
  AD_SPEND
  SHIPPING_COST
  SUBSCRIPTION_COST
  MARKETPLACE_COMMISSION
  OWNER_DRAW
  INSURANCE
  FUEL
  TAX
  VAT
  BANK_FEE
  MANUAL_ADJUSTMENT
  OTHER_EXPENSE
  OTHER_INCOME

  @@schema("public")
}

enum OperatingEventCategory {
  REVENUE
  DIRECT_COST
  MARKETING
  LOGISTICS
  SOFTWARE
  MARKETPLACE
  PERSONAL_DRAW
  TAXES
  FINANCE
  MANUAL
  OTHER

  @@schema("public")
}

enum OperatingDirection {
  IN
  OUT
  NEUTRAL

  @@schema("public")
}

enum OperatingSourceType {
  SHOPIFY_ORDER
  GALAXUS_ORDER_LINE
  DECATHLON_ORDER_LINE
  ORDER_MATCH
  GALAXUS_STOCKX_MATCH
  DECATHLON_STOCKX_MATCH
  DAILY_AD_SPEND
  MONTHLY_VARIABLE_COST
  RECURRING_EXPENSE
  PERSONAL_EXPENSE
  MANUAL_FINANCE_EVENT
  SYSTEM_GENERATED

  @@schema("public")
}

enum OperatingEventStatus {
  ACTIVE
  VOID
  SUPERSEDED
  PARTIAL
  PENDING_REVIEW

  @@schema("public")
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW

  @@schema("public")
}

enum ExpectedCashSourceType {
  OPERATING_EVENT
  MANUAL_FINANCE_EVENT
  RULE_GENERATED
  SYSTEM_GENERATED

  @@schema("public")
}

enum ExpectedCashDerivationMethod {
  RULE_BASED
  SAME_DAY
  OFFSET_DAYS
  MANUAL_OVERRIDE

  @@schema("public")
}

enum ExpectedCashStatus {
  PENDING
  ACTUALIZED
  VOID
  SUPERSEDED

  @@schema("public")
}

enum ReconciliationLinkedType {
  MANUAL_EVENT
  EXPECTED_CASH
  OPERATING_EVENT
  SHOPIFY_PAYOUT
  MARKETPLACE_REMITTANCE
  OTHER

  @@schema("public")
}

enum ReconciliationStatus {
  UNMATCHED
  MATCHED
  PARTIAL

  @@schema("public")
}

model ShopifyPayout {
  id               String   @id
  issuedAt         DateTime
  status           String
  transactionType  String?
  netAmount        Decimal  @db.Decimal(10, 2)
  currencyCode     String   @default("CHF")
  summaryJson      Json?
  rawJson          Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([issuedAt])
  @@schema("public")
}

model CashFlowConfig {
  id               String   @id @default(uuid())
  initialBalanceChf Decimal @db.Decimal(12, 2)
  currencyCode     String   @default("CHF")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@schema("public")
}

model CashInRule {
  id             String           @id @default(uuid())
  channel        MarketplaceChannel
  paymentMethod  String?
  delayType      CashInDelayType
  delayValueDays Decimal?         @db.Decimal(5, 2)
  priority       Int              @default(100)
  active         Boolean          @default(true)
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([channel, paymentMethod])
  @@index([active, priority])
  @@schema("public")
}

model CashOutRule {
  id          String        @id @default(uuid())
  category    CashOutCategory
  cadence     CashOutCadence
  amountChf   Decimal?      @db.Decimal(10, 2)
  dayOfWeek   Int?
  dayOfMonth  Int?
  offsetDays  Int?          // for shifting COGS outflow relative to order date
  startDate   DateTime?
  endDate     DateTime?
  active      Boolean       @default(true)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([category, active])
  @@schema("public")
}

model CashLedgerDaily {
  id             String   @id @default(uuid())
  date           DateTime
  openingBalance Decimal  @db.Decimal(12, 2)
  cashIn         Decimal  @db.Decimal(12, 2)
  cashOut        Decimal  @db.Decimal(12, 2)
  closingBalance Decimal  @db.Decimal(12, 2)
  metadataJson   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([date])
  @@index([date])
  @@schema("public")
}

model ForecastAssumption {
  id                  String          @id @default(uuid())
  channel             MarketplaceChannel
  mode                ForecastMode    @default(HYBRID)
  expectedDailySales  Decimal         @db.Decimal(12, 2) @default(0)
  expectedDailyOrders Int?
  growthRatePct       Decimal?        @db.Decimal(5, 2)
  payoutDelayDays     Decimal?        @db.Decimal(5, 2)
  commissionRatePct   Decimal?        @db.Decimal(5, 2)
  refundRatePct       Decimal?        @db.Decimal(5, 2)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([channel])
  @@schema("public")
}

model BankAccount {
  id           String          @id @default(uuid())
  name         String
  iban         String?         @unique
  bankName     String?
  currencyCode String          @default("CHF")
  accountType  BankAccountType @default(BANK)
  isPrimary    Boolean         @default(false)
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  imports           BankStatementImport[]
  transactions      BankTransaction[]
  balanceSnapshots  BankBalanceSnapshot[]
  manualEvents      ManualFinanceEvent[]

  @@schema("public")
}

model BankStatementImport {
  id             String           @id @default(uuid())
  bankAccountId  String
  sourceType     BankImportSource
  sourceFileName String?
  fileHash       String
  statementFrom  DateTime?
  statementTo    DateTime?
  importedAt     DateTime         @default(now())
  metadataJson   Json?

  bankAccount    BankAccount      @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  transactions   BankTransaction[]

  @@unique([bankAccountId, fileHash])
  @@index([bankAccountId, importedAt])
  @@schema("public")
}

model BankTransaction {
  id               String          @id @default(uuid())
  bankAccountId    String
  statementImportId String?
  externalId       String?
  bookingDate      DateTime
  valueDate        DateTime?
  amount           Decimal         @db.Decimal(12, 2)
  currencyCode     String          @default("CHF")
  direction        FinanceDirection
  counterpartyName String?
  counterpartyIban String?
  reference        String?
  remittanceInfo   String?
  transactionType  String?
  fingerprint      String
  rawJson          Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  bankAccount      BankAccount     @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  statementImport  BankStatementImport? @relation(fields: [statementImportId], references: [id], onDelete: SetNull)
  reconciliations  BankReconciliationLink[]
  expectedCashEvents ExpectedCashEvent[] @relation("ExpectedCashActualized")

  @@unique([bankAccountId, fingerprint])
  @@index([bankAccountId, bookingDate])
  @@index([bankAccountId, externalId])
  @@schema("public")
}

model BankBalanceSnapshot {
  id            String      @id @default(uuid())
  bankAccountId String
  snapshotDate  DateTime
  balance       Decimal     @db.Decimal(12, 2)
  currencyCode  String      @default("CHF")
  note          String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@unique([bankAccountId, snapshotDate])
  @@index([bankAccountId, snapshotDate])
  @@schema("public")
}

model ManualFinanceEvent {
  id               String             @id @default(uuid())
  eventDate        DateTime
  amount           Decimal            @db.Decimal(12, 2)
  currencyCode     String             @default("CHF")
  direction        FinanceDirection
  category         FinanceCategory    @default(OTHER)
  description      String?
  expenseCategoryId String?
  bankAccountId    String?
  sourceType       ManualEventSourceType @default(MANUAL)
  sourceId         String?
  metadataJson     Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  expenseCategory  ExpenseCategory?   @relation(fields: [expenseCategoryId], references: [id], onDelete: SetNull)
  bankAccount      BankAccount?       @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  operatingEvents  OperatingEvent[]   @relation("ManualFinanceOperatingEvents")
  expectedCashEvents ExpectedCashEvent[] @relation("ManualFinanceExpectedCashEvents")

  @@unique([sourceType, sourceId, eventDate])
  @@index([eventDate])
  @@index([sourceType, sourceId])
  @@schema("public")
}

model OperatingEvent {
  id           String                @id @default(uuid())
  eventKey     String                @unique
  eventDate    DateTime
  channel      MarketplaceChannel?
  eventType    OperatingEventType
  direction    OperatingDirection
  category     OperatingEventCategory
  subcategory  String?
  amount       Decimal               @db.Decimal(12, 2)
  currencyCode String                @default("CHF")
  description  String?

  sourceType    OperatingSourceType
  sourceRecordId String?
  sourceLineId  String?
  sourceTable   String?
  sourceReference String?
  paymentMethod String?
  materializedAt DateTime            @default(now())

  orderId          String?
  orderLineId      String?
  externalOrderRef String?
  sku              String?
  providerKey      String?
  counterparty     String?

  status       OperatingEventStatus @default(ACTIVE)
  confidence   ConfidenceLevel      @default(MEDIUM)
  isManual     Boolean              @default(false)
  isDerived    Boolean              @default(false)
  isEstimated  Boolean              @default(false)
  notes        String?
  metadataJson Json?

  manualFinanceEventId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  manualFinanceEvent ManualFinanceEvent? @relation("ManualFinanceOperatingEvents", fields: [manualFinanceEventId], references: [id], onDelete: SetNull)
  expectedCashEvents ExpectedCashEvent[] @relation("OperatingExpectedCash")

  @@index([eventDate])
  @@index([channel])
  @@index([sourceType])
  @@index([sourceRecordId])
  @@schema("public")
}

model ExpectedCashEvent {
  id             String                @id @default(uuid())
  expectedEventKey String              @unique
  expectedDate   DateTime
  amount         Decimal               @db.Decimal(12, 2)
  currencyCode   String                @default("CHF")
  direction      FinanceDirection
  category       FinanceCategory       @default(OTHER)
  subcategory    String?
  description    String?
  channel        MarketplaceChannel?
  paymentMethod  String?

  sourceType       ExpectedCashSourceType
  sourceRuleId     String?
  derivationMethod ExpectedCashDerivationMethod
  derivationVersion String?

  operatingEventId           String?
  manualFinanceEventId       String?
  isActualized               Boolean              @default(false)
  actualizedByBankTransactionId String?
  status                     ExpectedCashStatus   @default(PENDING)
  confidence                 ConfidenceLevel      @default(MEDIUM)
  notes                      String?
  metadataJson               Json?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt

  operatingEvent        OperatingEvent?     @relation("OperatingExpectedCash", fields: [operatingEventId], references: [id], onDelete: SetNull)
  manualFinanceEvent    ManualFinanceEvent? @relation("ManualFinanceExpectedCashEvents", fields: [manualFinanceEventId], references: [id], onDelete: SetNull)
  actualizedByBankTransaction BankTransaction? @relation("ExpectedCashActualized", fields: [actualizedByBankTransactionId], references: [id], onDelete: SetNull)

  @@index([expectedDate])
  @@index([channel])
  @@index([sourceType])
  @@index([operatingEventId])
  @@schema("public")
}

model BankReconciliationLink {
  id               String                 @id @default(uuid())
  bankTransactionId String
  linkedType       ReconciliationLinkedType
  linkedId         String
  status           ReconciliationStatus   @default(MATCHED)
  matchedAmount    Decimal?               @db.Decimal(12, 2)
  confidence       Int?
  notes            String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  bankTransaction  BankTransaction        @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)

  @@index([linkedType, linkedId])
  @@index([status])
  @@schema("public")
}

model MarketplaceCashAssumption {
  id           String             @id @default(uuid())
  channel      MarketplaceChannel
  lagDays      Int                @default(2)
  feePercent   Decimal?           @db.Decimal(5, 2)
  feeFlatChf   Decimal?           @db.Decimal(10, 2)
  activeFrom   DateTime           @default(now())
  activeTo     DateTime?
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([channel, activeFrom])
  @@schema("public")
}

model MarketplaceRemittance {
  id           String             @id @default(uuid())
  channel      MarketplaceChannel
  paidAt       DateTime
  amountChf    Decimal            @db.Decimal(10, 2)
  currencyCode String             @default("CHF")
  reference    String?
  sourceFile   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([channel, paidAt])
  @@schema("public")
}

enum DocumentType {
  INVOICE
  DELIVERY_NOTE
  LABEL

